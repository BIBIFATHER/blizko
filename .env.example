# Blizko environment template
# Do not commit real secrets. Copy to .env.local (dev) or set in hosting env vars.

# Server-side AI key used by api/ai.ts
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model override (if api/ai.ts starts reading it in future)
# GEMINI_MODEL=gemini-2.0-flash

# Twilio Verify (real SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (server-side persistence)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase (client-side, exposed to the browser via Vite).
# MUST be the canonical project REST host, NOT a proxy/worker — the client hits
# /rest/v1, /auth/v1, /storage/v1 on this origin. Pointing it at the SEO worker
# (or any partial proxy) returns 404 on REST calls (see BLI-93).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key

# Notifications (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Blizko <no-reply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_EMAILS=admin@yourdomain.com,owner@yourdomain.com
NOTIFY_TOKEN=your_notify_secret

# Admin panel access (client-side allowlist)
VITE_ADMIN_EMAILS=admin@yourdomain.com,owner@yourdomain.com

# Sentry (client + build-time)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=blizko-web
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Auth rollout flags
VITE_ENABLE_PHONE_AUTH=false

# Synthetic-only closed contour (until RU-core). Default = ON (closed): the app
# is a dev/staging environment on synthetic data only. Real users, real personal
# data, and production payments are NOT admitted; all product features stay on
# for testing on fictional data. Set to 'false' (both) only after RU-core
# readiness + owner Go — no UI/business-logic rewrite needed, just these flags
# plus opened admission. Missing value fails closed (stays ON).
# BLIZKO_SYNTHETIC_ONLY=true            # server: closes real-user admission
# VITE_SYNTHETIC_ONLY=true              # client: restored-session/admission checks
#
# Identities admitted to the closed contour. Used both for new logins AND to
# sign out / reject restored sessions and existing JWTs that are not allow-listed.
# Set your own test phone(s)/email(s) so you can log in; everyone else is closed.
#
# Phones (E.164, comma-separated). Server gates OTP send/verify + authenticated
# API identity; client signs out non-allow-listed restored phone sessions.
# TEST_OTP_PHONE is always included server-side.
# SYNTHETIC_TEST_PHONES=+79990000000        # server (OTP + API identity)
# VITE_SYNTHETIC_TEST_PHONES=+79990000000   # client (restored-session check)
#
# Emails (comma-separated). Server gates authenticated API identity; client gates
# email magic-link sign-in + restored-session check. Email magic-link goes
# straight to Supabase Auth, so these are defense-in-depth; the HARD enforcement
# is the Supabase Auth project config (disable/restrict open email signups) plus
# revoking existing sessions — required before any real user could reach the app.
# SYNTHETIC_TEST_EMAILS=you@example.com       # server
# VITE_SYNTHETIC_TEST_EMAILS=you@example.com  # client
#
# Payments: real payments are not used in this development contour. The code
# enforces admission only and does NOT verify test-vs-production YooKassa keys —
# enabling real payments is a separate pre-open gate. Keep test keys here; do not
# set production payment keys until RU-core + owner Go.

# External AI on personal data is blocked by jurisdiction policy when
# synthetic-only is off. This gate defaults closed; set to true only after the
# cross-border AI gate is reviewed and approved for the applicable jurisdiction.
# BLIZKO_CROSS_BORDER_AI_GATE_OPEN=false
#
# Sensitive AI flows (documents, child/family context, health/special-category
# risk) require a separate approval. Current AI endpoints are sensitive-capable,
# so both gates must be true before they can process real RU personal data.
# BLIZKO_SENSITIVE_AI_FLOW_GATE_OPEN=false
#
# External notification processors (Resend/Telegram) remain closed for real
# personal-data flows until separately approved for the target contour.
# BLIZKO_EXTERNAL_NOTIFICATION_GATE_OPEN=false
#
# External geocoding (/api/geocode -> Yandex/Nominatim) is unauthenticated and
# forwards free-text address + GPS. CLOSED BY DEFAULT regardless of
# synthetic-only: a real visitor on the live site can type a real address, so
# synthetic-only does not make this input synthetic (BLI-119). Set to 'true'
# only for local dev (to test autocomplete) or after legal acceptance of the
# public path. When closed the form degrades gracefully (no autocomplete; manual
# city entry works). Before opening for real data: register Yandex Geocoder +
# Nominatim in PROCESSOR_REGISTER, add the flow to DATA_REGISTER, and record
# legal/security acceptance (or add auth/jurisdiction routing). See Linear BLI-119.
# BLIZKO_GEOCODE_EGRESS_GATE_OPEN=false

# Supabase storage buckets
VITE_SUPABASE_VIDEO_BUCKET=nanny-videos
VITE_SUPABASE_DOCS_BUCKET=nanny-documents
VITE_SUPABASE_PHOTOS_BUCKET=nanny-photos

# Telegram (support escalation notifications)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ADMIN_CHAT_ID=-100xxxxxxxxxx

# SMSAero (phone verification)
SMSAERO_EMAIL=you@example.com
SMSAERO_API_KEY=xxxxxxxxxxxxxxxx
SMSAERO_SIGN=SMS Aero
