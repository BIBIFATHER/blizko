{
  "name": "blizko",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "env:doctor": "bash -lc 'for v in VITE_SUPABASE_URL VITE_SUPABASE_ANON_KEY VITE_SENTRY_DSN SUPABASE_URL SUPABASE_SERVICE_ROLE_KEY NOTIFY_TOKEN SENTRY_ORG SENTRY_PROJECT SENTRY_AUTH_TOKEN; do if [ -n \"${!v:-}\" ]; then echo \"$v=present\"; else echo \"$v=missing\"; fi; done'",
    "env:doctor:local": "bash scripts/with-env.sh npm run env:doctor",
    "build": "vite build",
    "preview": "vite preview",
    "check:chat-rls": "bash scripts/check_chat_messages_rls.sh",
    "check:chat-rls-matrix": "bash scripts/check_chat_messages_rls_matrix.sh",
    "check:nannies-rls": "bash scripts/check_nannies_rls.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "release:gate": "bash scripts/release-gate.sh",
    "format": "prettier --write '**/*.{ts,tsx,js,json,css,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,json,css,md}'",
    "review:codex": "bash scripts/review-with-codex.sh",
    "review:claude": "bash scripts/review-with-claude.sh",
    "guard:git-scope": "bash scripts/git-scope-guard.sh",
    "guard:git-scope:test": "bash scripts/__tests__/git-scope-guard.test.sh",
    "review:timeout:test": "node scripts/__tests__/run-with-timeout.test.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "leads": "node scripts/nannyLeadRegistry.js",
    "seed": "node scripts/importHhNannies.js",
    "seed:hh": "node scripts/parseHhResponses.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@google/genai": "^1.33.0",
    "@sentry/react": "^10.38.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@supabase/supabase-js": "^2.95.3",
    "clsx": "^2.1.1",
    "csv-parser": "^3.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.561.0",
    "pg": "^8.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^3.0.0",
    "react-qr-code": "2.0.15",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vercel/node": "^5.5.16",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.0"
  }
}
